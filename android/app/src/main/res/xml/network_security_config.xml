<?xml version="1.0" encoding="utf-8"?>
<!--
    ✅ هذا الملف يسمح للتطبيق بالاتصال بروابط HTTP (غير مشفرة)
    وهو ضروري لتشغيل بثوث IPTV التي تستخدم بروتوكول HTTP
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </base-config>
</network-security-config>
